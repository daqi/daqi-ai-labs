    {
      "id": "5opTjXQL-jNP8ogjz5XeQ",
      "type": "text",
      "x": -1735.27828252674,
      "y": 561.6136826018053,
      "width": 240,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
